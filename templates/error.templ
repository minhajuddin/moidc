package templates

templ Error(title, message string) {
	@Layout("Error") {
		<div class="space-y-6">
			<h1 class="text-2xl font-bold text-red-400">{ title }</h1>
			<div class="bg-red-900/30 border border-red-700/50 rounded-lg p-4">
				<p class="text-red-300">{ message }</p>
			</div>
			<a href="/" class="inline-block text-cyan-400 hover:text-cyan-300 hover:underline">Back to home</a>
		</div>
	}
}
